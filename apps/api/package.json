  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cron": "^2.0.0",
    "@types/dockerode": "^4.0.1",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/pg": "^8.20.0",
    "@types/tar-stream": "^3.1.4",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "prisma": "^5.22.0",
    "ts-jest": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
