# FIDScript Deploy Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/fidscript"

# Redis
REDIS_URL="redis://localhost:6379"

# NATS
NATS_URL="nats://localhost:4222"

# JWT
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"

# API
API_PORT=3000
API_URL="http://localhost:3000"
API_CORS_ORIGINS="http://localhost:3001"

# Dashboard
DASHBOARD_PORT=3001
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Storage (MinIO)
S3_ENDPOINT="localhost"
S3_PORT=9000
S3_USE_SSL=false
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="fidscript"

# Email (Stalwart)
SMTP_HOST="localhost"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@fidscript.local"

# Cloudflare (for DNS)
CLOUDFLARE_API_KEY=""
CLOUDFLARE_EMAIL=""

# AI Providers
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# Node Environment
NODE_ENV="development"
