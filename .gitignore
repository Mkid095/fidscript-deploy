# Installer — generated secrets (never commit). The setup-wizard creates
# these in installer/docker/secrets/ and they're root-only. Keep them out
# of git; developers generate their own on first run.
installer/docker/secrets/
installer/docker/.env
installer/docker/userlist.txt

# Stalwart rendered config — contains a bcrypt hash of the platform
# admin token. setup-wizard.sh regenerates from the .template on every
# install; never commit the rendered version.
installer/config/stalwart/config.toml
